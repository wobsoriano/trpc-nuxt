{
  "name": "trpc-nuxt",
  "version": "2.0.2",
  "description": "End-to-end typesafe APIs in Nuxt applications.",
  "homepage": "https://github.com/wobsoriano/trpc-nuxt#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wobsoriano/trpc-nuxt.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.mts",
      "import": "./dist/client/index.mjs"
    },
    "./server": {
      "types": "./dist/server/index.d.mts",
      "import": "./dist/server/index.mjs"
    }
  },
  "scripts": {
    "dev": "vp pack --watch",
    "dev:prepare": "pnpm build && nuxt prepare playground",
    "prepublishOnly": "pnpm build",
    "build": "vp pack",
    "format": "vp fmt",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "release": "changeset publish",
    "prepare": "vp config"
  },
  "dependencies": {
    "h3": "^1.15.6",
    "ofetch": "^1.5.1",
    "ohash": "^2.0.11"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@trpc/client": "catalog:trpc",
    "@trpc/server": "catalog:trpc",
    "eslint": "^9.39.2",
    "nuxt": "catalog:repo",
    "rolldown": "catalog:repo",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue": "^3.5.30"
  },
  "peerDependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.26.0"
}
